<?xml version="1.0"?>
<robot name="thrusters" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- virtual root so this file visualises standalone -->
  <link name="thrusters_base" />

  <!-- carrying link -->
  <link name="link1_arm_roll">
    <inertial>
      <origin xyz="0.391146951699728 0.562691269918003 -1.40979996564852" rpy="0 0 0" />
      <mass value="0.236214339843921" />
      <inertia ixx="0.000102401751755143" ixy="-4.32094643119988E-06" ixz="-2.34507039099166E-07"
               iyy="9.86396832914087E-05" iyz="-3.46801744834344E-07" izz="7.99788746652359E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://serial-articulated/meshes/link1_arm_roll.STL" />
      </geometry>
      <material name="slate">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://serial-articulated/meshes/link1_arm_roll.STL" />
      </geometry>
    </collision>
  </link>

  <!-- servo output frames (massless, no geometry) -->
  <link name="link1_right_tilt" />
  <link name="link1_left_tilt" />

  <!-- right propeller -->
  <link name="link1_right_spin">
    <inertial>
      <origin xyz="6.93158392350846E-07 6.29945029195778E-08 0.00430821663494839" rpy="0 0 0" />
      <mass value="0.0119145513741783" />
      <inertia ixx="4.76119684476372E-07" ixy="-1.11645184011423E-06" ixz="-5.15182079685355E-12"
               iyy="2.0399736262995E-05" iyz="-2.98523010228511E-12" izz="2.05871235175461E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://serial-articulated/meshes/link1_right_spin.STL" />
      </geometry>
      <material name="slate">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://serial-articulated/meshes/link1_right_spin.STL" />
      </geometry>
    </collision>
  </link>

  <!-- left propeller -->
  <link name="link1_left_spin">
    <inertial>
      <origin xyz="-6.65762375562373E-07 7.51971221471526E-08 0.00430822010087943" rpy="0 0 0" />
      <mass value="0.0119145619562564" />
      <inertia ixx="8.92563367215736E-07" ixy="3.06123858172512E-06" ixz="5.66717622274926E-12"
               iyy="1.99835060436476E-05" iyz="1.6706195567006E-12" izz="2.05873388306E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://serial-articulated/meshes/link1_left_spin.STL" />
      </geometry>
      <material name="slate">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://serial-articulated/meshes/link1_left_spin.STL" />
      </geometry>
    </collision>
  </link>

  <!-- joints -->
  <joint name="arm_mount" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="thrusters_base" />
    <child link="link1_arm_roll" />
  </joint>

  <!-- right servo at prop mount, axis perpendicular to right spin axis -->
  <joint name="link1_right_servo" type="revolute">
    <origin xyz="0.44002 0.52942 -1.5835" rpy="0 0 0" />
    <parent link="link1_arm_roll" />
    <child link="link1_right_tilt" />
    <axis xyz="0.98248 0 -0.18627" />
    <limit lower="-1.5708" upper="1.5708" effort="1.0" velocity="1.0" />
  </joint>

  <!-- right prop spins at tilt origin (no position change) -->
  <joint name="link1_right_prop" type="continuous">
    <origin xyz="0 0 0" rpy="-1.5798 -1.5473 0.97838" />
    <parent link="link1_right_tilt" />
    <child link="link1_right_spin" />
    <axis xyz="-0.18627 0.0062962 -0.98248" />
  </joint>

  <!-- left servo at prop mount, axis perpendicular to left spin axis -->
  <joint name="link1_left_servo" type="revolute">
    <origin xyz="0.44605 0.53925 -1.237" rpy="0 0 0" />
    <parent link="link1_arm_roll" />
    <child link="link1_left_tilt" />
    <axis xyz="0.99879 0 0" />
    <limit lower="-1.5708" upper="1.5708" effort="1.0" velocity="1.0" />
  </joint>

  <!-- left prop spins at tilt origin (no position change) -->
  <joint name="link1_left_prop" type="continuous">
    <origin xyz="0 0 0" rpy="1.5306 1.5473 -2.1632" />
    <parent link="link1_left_tilt" />
    <child link="link1_left_spin" />
    <axis xyz="0 0.049088 -0.99879" />
  </joint>

</robot>
